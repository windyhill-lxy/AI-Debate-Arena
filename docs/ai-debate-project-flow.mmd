%% AI 辩论场项目流程图
%% 按当前项目代码的真实运行顺序整理，节点文字使用自然语言。
flowchart LR
  subgraph Legend["图例"]
    direction TB
    L0["普通步骤"]
    L1{"系统检查"}
    L2{"智能判断"}
    L3[("保存结果")]
  end

  subgraph Setup["一、房间准备：先准备辩题和资料"]
    direction TB
    S0["打开首页或联机邀请入口"]
    S1{"选择本地辩论还是多人联机"}
    S2["填写辩题、赛制、席位和参考资料"]
    S3["房主填写辩题、赛制、观看权限和参考资料"]
    S4["点击下一步"]
    S5["保存一份用于搜集论据的准备记录"]
    S6["后台提前搜集双方开场论据"]
    S7{"是否返回修改辩题或资料"}
    S8["停止使用旧的搜集结果"]
    S9["重新点击下一步后开始新的搜集"]
    S10["继续选择席位和是否使用摄像头"]
    S11["创建正式辩论房间"]

    S0 --> S1
    S1 -->|本地| S2
    S1 -->|联机| S3
    S2 --> S4
    S3 --> S4
    S4 --> S5
    S5 --> S6
    S6 --> S7
    S7 -->|修改了| S8
    S8 --> S9
    S9 --> S5
    S7 -->|继续| S10
    S10 --> S11
  end

  subgraph Evidence["二、开场论据：在正式辩论前尽量准备好"]
    direction TB
    E0["读取最新辩题和资料"]
    E1{"辩题仍然一致"}
    E2["为正方寻找真实事实、案例和数据"]
    E3["为反方寻找真实事实、案例和数据"]
    E4{"资料是否可信、是否能用于辩论"}
    E5["丢弃不合格资料并继续补充"]
    E6["整理成双方公开论据库"]
    E7["给每条论据分配稳定编号"]
    E8{"双方论据是否达到目标数量"}
    E9[("保存论据库和就绪状态")]
    E10["只更新论据库，不覆盖房间成员和比赛进度"]
    E11["丢弃过期搜集结果"]

    E0 --> E1
    E1 -->|否| E11
    E1 -->|是| E2
    E2 --> E3
    E3 --> E4
    E4 -->|否| E5
    E5 --> E2
    E4 -->|是| E6
    E6 --> E7
    E7 --> E8
    E8 -->|还不够| E2
    E8 -->|已就绪或已尽力| E9
    E9 --> E10
  end

  subgraph Room["三、进入房间：把准备结果带入正式比赛"]
    direction TB
    R0["收到创建正式房间请求"]
    R1{"是否已有提前搜集的论据"}
    R2["读取提前搜集结果"]
    R3{"辩题与当前房间一致"}
    R4["合并提前准备好的论据库"]
    R5["使用空论据库或资料生成的初始论据"]
    R6[("保存正式房间状态")]
    R7["再启动一次后台搜集作为兜底"]
    R8{"是否多人联机"}
    R9["房主和宾客完成选座"]
    R10["进入辩论室"]

    R0 --> R1
    R1 -->|是| R2
    R2 --> R3
    R3 -->|一致| R4
    R3 -->|不一致| R5
    R1 -->|否| R5
    R4 --> R6
    R5 --> R6
    R6 --> R7
    R7 --> R8
    R8 -->|是| R9
    R8 -->|否| R10
    R9 --> R10
  end

  subgraph Schedule["四、正式赛程：先有论据，再让一辩分配任务"]
    direction TB
    D0["裁判开场并说明规则"]
    D1["检查开场论据库"]
    D2{"双方论据是否准备好"}
    D3["等待后台搜集完成"]
    D4["正方一辩分配立论任务"]
    D5["反方一辩分配立论任务"]
    D6["检查任务是否合理"]
    D7["确认论点分工"]
    D8["确认论据分配"]
    D9["正方队内讨论立论策略"]
    D10["反方队内讨论立论策略"]
    D11["锁定开篇立论策略"]

    D0 --> D1
    D1 --> D2
    D2 -->|否| D3
    D3 --> D2
    D2 -->|是| D4
    D4 --> D5
    D5 --> D6
    D6 --> D7
    D7 --> D8
    D8 --> D9
    D9 --> D10
    D10 --> D11
  end

  subgraph Team["五、队内讨论：真人席位真人说，空席位由智能队友补充"]
    direction TB
    T0["进入本方队内讨论"]
    T1["读取本方论据库、当前分工和已发言记录"]
    T2{"这个席位是否已经在本轮说过"}
    T3["跳过该席位，避免重复发言"]
    T4{"这个席位是否已被真人选走"}
    T5["暂停自动推进，等待该真人发言"]
    T6["真人提交队内发言"]
    T7["智能队友生成自己的队内建议"]
    T8["自动补上本方论据编号"]
    T9[("记录本段已处理席位")]
    T10{"本方是否还有未处理席位"}
    T11["进入下一位队友"]
    T12["本方队内讨论完成，继续赛程"]

    T0 --> T1
    T1 --> T2
    T2 -->|是| T3
    T3 --> T10
    T2 -->|否| T4
    T4 -->|是| T5
    T5 --> T6
    T6 --> T9
    T4 -->|否| T7
    T7 --> T8
    T8 --> T9
    T9 --> T10
    T10 -->|有| T11
    T11 --> T2
    T10 -->|没有| T12
  end

  subgraph Public["六、公开辩论：按赛程轮流发言"]
    direction TB
    P0["进入公开发言环节"]
    P1{"当前发言席位是否是真人"}
    P2["暂停自动推进，等待真人输入"]
    P3["检查是否轮到本人以及是否引用论据"]
    P4["保存发言、评分并处理超时"]
    P5["智能辩手或裁判生成发言"]
    P6["发布公开消息"]
    P7["推进到下一赛程步骤"]
    P8{"比赛是否结束"}
    P9["继续下一轮发言"]
    P10["裁判汇总得分和理由"]
    P11["生成最终报告和回放"]

    P0 --> P1
    P1 -->|是| P2
    P2 --> P3
    P3 --> P4
    P4 --> P6
    P1 -->|否| P5
    P5 --> P6
    P6 --> P7
    P7 --> P8
    P8 -->|否| P9
    P9 --> P1
    P8 -->|是| P10
    P10 --> P11
  end

  subgraph View["七、页面显示与摄像头：只提示用户需要知道的事"]
    direction TB
    V0["实时接收房间状态"]
    V1["刷新主舞台、侧栏、论据库和流程图"]
    V2{"用户选择的观看方式"}
    V3["全知视角显示全部内容"]
    V4["上下文视角显示本方内部内容和公开内容"]
    V5["真实比赛视角隐藏内部策略"]
    V6{"用户是否选择使用摄像头"}
    V7["不打开摄像头，也不弹摄像头错误"]
    V8["尝试打开摄像头"]
    V9{"摄像头是否可用"}
    V10["显示本地和对方画面"]
    V11["第一次失败时弹出提示"]
    V12["后续失败只在顶部小字提示"]
    V13["接口、语音或实时连接出错"]
    V14["整理成用户可读提示"]
    V15["显示错误窗口"]

    V0 --> V1
    V1 --> V2
    V2 -->|全知| V3
    V2 -->|上下文| V4
    V2 -->|真实比赛| V5
    V1 --> V6
    V6 -->|否| V7
    V6 -->|是| V8
    V8 --> V9
    V9 -->|可用| V10
    V9 -->|不可用| V11
    V11 --> V12
    V13 --> V14
    V14 --> V15
  end

  S6 --> E0
  S11 --> R0
  R7 --> E0
  R10 --> D0
  E10 -. "更新论据就绪状态" .-> D2
  D11 --> T0
  T12 --> P0
  P6 --> V0
  P11 --> V0

  classDef action fill:#f7f2e8,stroke:#9a7a3f,color:#1f1a12;
  classDef program fill:#e8f1ff,stroke:#4f7db8,color:#0f2037;
  classDef ai fill:#f2eaff,stroke:#7a5db4,color:#21153a;
  classDef state fill:#eaf6ed,stroke:#4d8757,color:#102815;
  classDef error fill:#fde8e8,stroke:#b85555,color:#2b1010;

  class S0,S2,S3,S4,S5,S6,S8,S9,S10,S11,E0,E2,E3,E5,E6,E7,E10,E11,R0,R2,R4,R5,R7,R9,R10,D0,D1,D3,D4,D5,D6,D7,D8,D9,D10,D11,T0,T1,T3,T5,T6,T7,T8,T11,T12,P0,P2,P3,P4,P5,P6,P7,P9,P10,P11,V0,V1,V3,V4,V5,V7,V8,V10,V11,V12,V14,V15,L0 action;
  class S1,S7,E1,E8,R1,R3,R8,D2,T2,T4,T10,P1,P8,V2,V6,V9,L1 program;
  class E4,L2 ai;
  class E9,R6,T9,L3 state;
  class V13 error;
