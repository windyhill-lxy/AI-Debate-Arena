APP_NAME=AI Debate Arena
BACKEND_HOST=127.0.0.1
BACKEND_PORT=9000
FRONTEND_PORT=5173

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=ai_debate_arena
REDIS_URL=redis://localhost:6379/0

# Optional model keys. The app falls back to demo responses without them.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
DEEPSEEK_FALLBACK_MODELS=
# dsapi 等兼容网关支持联网搜索时可开启；base url 含 dsapi 时也会自动尝试。
DEEPSEEK_AUTO_SEARCH=false

LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 公网隧道（推荐 ngrok，比 Cloudflare 临时链接稳定）
# 免费注册：https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=
# TUNNEL_PROVIDER=auto

# 公网隧道 HTTP 代理（国内网络访问 Cloudflare 时常用，与 Clash/V2Ray 本地端口一致）
# TUNNEL_HTTP_PROXY=http://127.0.0.1:7890
# TUNNEL_HTTPS_PROXY=http://127.0.0.1:7890
DEEPSEEK_PRO_PHASES=closing,post_match
API_RATE_LIMIT_CREATE_PER_MIN=30
API_RATE_LIMIT_WRITE_PER_MIN=120

# TTS model: Aliyun Model Studio / DashScope Qwen3-TTS. Keep the real key only in .env.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
ALIYUN_TTS_ENABLED=true
ALIYUN_TTS_MODEL=qwen3-tts-instruct-flash
ALIYUN_TTS_LANGUAGE_TYPE=Chinese

# Speech input model: Aliyun Intelligent Speech Interaction ASR. Keep real AccessKeys only in .env.
ALIYUN_ASR_ENABLED=true
ALIYUN_AK_ID=
ALIYUN_AK_SECRET=
ALIYUN_ISI_APPKEY=
ALIYUN_ASR_REGION=cn-shanghai
ALIYUN_ASR_SAMPLE_RATE=16000
ALIYUN_ASR_ENDPOINT=https://nls-gateway-cn-shanghai.aliyuncs.com/stream/v1/asr
ALIYUN_TOKEN_ENDPOINT=https://nls-meta.cn-shanghai.aliyuncs.com/

RAG_TOP_K=4
SCHEDULE_TEMPLATE=formal_4v4
# 仅以下 phase 合成 TTS（逗号分隔，减轻队列积压）
TTS_PHASES=opening_statement,cross_examination,closing,post_match
DEBATE_TURN_SECONDS=90

# LLM models. These keys can also be saved from the System Management page.
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_FLASH_MODEL=qwen-turbo

KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k
KIMI_FLASH_MODEL=moonshot-v1-8k

MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M2.1-highspeed
MINIMAX_FLASH_MODEL=MiniMax-M2.1-highspeed
MINIMAX_TTS_MODEL=speech-01-turbo
MINIMAX_TTS_VOICE_ID=female-shaonv
